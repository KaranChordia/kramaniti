      "frequency": "per_request",
      "outputs": ["bottleneck analysis", "opportunity maps"]
    },
    {
      "task": "Create implementation roadmaps.",
      "frequency": "as_needed",
      "outputs": ["implementation roadmaps"]
    },
    {
      "task": "Define prototype specifications and team handoff needs.",
      "frequency": "as_needed",
      "outputs": ["prototype specs", "handoff requirements"]
    }
