      "role": "Identify where systems can create the most practical improvement.",
      "tasks": [
        "Draft audit questions.",
        "Document findings.",
        "Create opportunity maps.",
        "Prepare readiness notes."
      ],
      "escalation_triggers": [
        "Recommending tools before the workflow is understood."
